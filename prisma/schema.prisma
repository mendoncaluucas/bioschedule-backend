generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  ADMIN
  PROFISSIONAL
}

model Usuario {
  id            String        @id @default(uuid())
  nome          String
  email         String        @unique
  senha         String
  role          Role          @default(PROFISSIONAL)
  ativo         Boolean       @default(true)
  criado_em     DateTime      @default(now())
  atualizado_em DateTime      @updatedAt
  agendamentos  Agendamento[]

  @@map("usuarios")
}

model Paciente {
  id           String         @id @default(uuid())
  nome         String
  cpf          String         @unique
  telefone     String
  email        String?
  observacoes  String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  fotos        FotoPaciente[]
  agendamentos Agendamento[]

  @@map("pacientes")
}

model FotoPaciente {
  id         String   @id @default(uuid())
  url        String
  legenda    String?
  criado_em  DateTime @default(now())
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  pacienteId String

  @@map("fotos_pacientes")
}

model Servico {
  id              String        @id @default(uuid())
  nome            String
  duracao_minutos Int
  valor           Decimal       @db.Decimal(10, 2)
  ativo           Boolean       @default(true)
  agendamentos    Agendamento[]

  @@map("servicos")
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  CANCELADO
  CONCLUIDO
  FALTOU
}

model Agendamento {
  id             String            @id @default(uuid())
  data_inicio    DateTime
  data_fim       DateTime
  status         StatusAgendamento @default(AGENDADO)
  observacoes    String?           @db.Text
  createdAt      DateTime          @default(now())
  paciente       Paciente          @relation(fields: [pacienteId], references: [id])
  pacienteId     String
  servico        Servico           @relation(fields: [servicoId], references: [id])
  servicoId      String
  profissional   Usuario           @relation(fields: [profissionalId], references: [id])
  profissionalId String

  @@map("agendamentos")
}

model Bloqueio {
  id          String   @id @default(uuid())
  data_inicio DateTime
  data_fim    DateTime
  motivo      String?
  criado_em   DateTime @default(now())

  @@map("bloqueios")
}

model ConfiguracaoAgenda {
  id            Int     @id @default(autoincrement())
  dia_semana    Int     @unique
  nome          String
  ativo         Boolean @default(true)
  abertura      String
  fechamento    String
  almoco_inicio String
  almoco_fim    String

  @@map("configuracoes_agenda")
}